<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <UseWindowsForms>false</UseWindowsForms>
    <Nullable>enable</Nullable>
    <RootNamespace>AnimationGame</RootNamespace>
    <AssemblyName>AnimationGame</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MonoGame.Framework.WindowsDX" Version="3.8.1.25" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Content/**/*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
